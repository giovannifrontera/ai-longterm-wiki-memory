{
  "id": "wiki-context-plugin",
  "name": "Wiki Context Injector",
  "description": "Injects relevant wiki pages into every prompt via before_prompt_build. Requires wiki_context.py from ai-wiki-system.",
  "contracts": {
    "tools": [],
    "hooks": ["before_prompt_build"]
  },
  "activation": {
    "onStartup": true,
    "allowConversationAccess": true,
    "allowPromptInjection": true
  },
  "configSchema": {
    "type": "object",
    "required": ["workspace", "wikiContextScript"],
    "properties": {
      "workspace": {
        "type": "string",
        "description": "Absolute path to the wiki workspace (directory containing wiki.config.json)"
      },
      "wikiContextScript": {
        "type": "string",
        "description": "Absolute path to wiki_context.py (e.g. /path/to/ai-wiki-system/scripts/wiki_context.py)"
      },
      "pythonExecutable": {
        "type": "string",
        "default": "python",
        "description": "Python executable to use. Use 'py' on Windows or full path if needed."
      },
      "k": {
        "type": "integer",
        "default": 3,
        "description": "Number of wiki pages to inject per prompt"
      },
      "maxChars": {
        "type": "integer",
        "default": 600,
        "description": "Maximum characters per page excerpt"
      },
      "timeoutMs": {
        "type": "integer",
        "default": 15000,
        "description": "Timeout for wiki_context.py in milliseconds"
      }
    }
  }
}
